# ============================================================
# AI交易器 - 环境配置文件示例
# ============================================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 根据实际情况修改配置值
# 3. .env 文件不会被提交到 git 仓库
# ============================================================
# ============ 安全配置 ============
# Flask Session密钥（生产环境必须修改为随机字符串）
# 生成方法：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# ============ 服务器配置 ============
# 服务器监听地址（0.0.0.0表示监听所有网卡）
HOST=0.0.0.0
# 服务器端口
PORT=35008
# 调试模式（生产环境请设置为False）
DEBUG=False
# ============ 数据库配置 ============
# SQLite数据库文件路径
DATABASE_PATH=trading_bot.db
# ============ 交易配置 ============
# 是否启用自动交易
AUTO_TRADING=True
# 交易循环间隔（秒）
TRADING_INTERVAL=180
# ============ 交易模式 ============
TRADING_MODE=okx_demo
# ============ OKX API配置 ============
OKX_API_KEY=cfdb8f59-d2a4-4be1-8675-6f16e19e22de
OKX_API_SECRET=293C6B25518060439A29E0ABBE1CD2E9
OKX_API_PASSPHRASE=Mengbaowang666.
# ============ 交易间隔 ============
TRADING_INTERVAL=300
# ============ 日志配置 ============
# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# ============================================================
# 注意事项：
# 1. 请勿将 .env 文件提交到版本控制系统
# 2. 生产环境请使用强密码和安全的配置
# 3. 定期更新 OAuth 密钥
# 4. 确保数据库文件有适当的访问权限
# ============================================================